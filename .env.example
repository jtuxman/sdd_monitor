# Ruta al archivo de base de datos SQLite (relativa al directorio raíz del proyecto)
DB_PATH=data/metrics.db

# Intervalo de polling en segundos
POLL_INTERVAL=60

# Credenciales SNMP v3 (solo necesarias si se usan dispositivos con snmp_version: 3)
SNMPV3_USERNAME=monitor
SNMPV3_AUTH_PROTOCOL=SHA        # SHA o MD5
SNMPV3_PRIV_PROTOCOL=AES        # AES o DES
SNMPV3_AUTH_KEY=cambiar_esta_clave_auth
SNMPV3_PRIV_KEY=cambiar_esta_clave_priv
